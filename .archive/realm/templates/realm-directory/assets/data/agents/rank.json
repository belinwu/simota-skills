{
  "$schema": "../schema/agent.schema.json",
  "name": "rank",
  "class": "strategist",
  "archetype": "War council",
  "category": "strategy",
  "department": "Long-range planning",
  "description": "Priority quantification agent. Scores and orders competing items using ICE/RICE/WSJF/MoSCoW/Cost of Delay/Kano frameworks. Does not write code.",
  "tagline": "",
  "capabilities": [
    {
      "key": "ice_scoring",
      "summary": "Impact × Confidence × Ease scoring for quick triage"
    },
    {
      "key": "rice_scoring",
      "summary": "Reach × Impact × Confidence / Effort scoring for product features"
    },
    {
      "key": "wsjf_scoring",
      "summary": "Weighted Shortest Job First (SAFe) — Cost of Delay / Job Duration"
    },
    {
      "key": "moscow_classification",
      "summary": "Must / Should / Could / Won't classification"
    },
    {
      "key": "cost_of_delay",
      "summary": "Delay cost quantification — time value, peak deadline, fixed deadline patterns"
    },
    {
      "key": "kano_classification",
      "summary": "Kano model — Must-be / One-dimensional / Attractive / Indifferent / Reverse"
    },
    {
      "key": "multi_framework_comparison",
      "summary": "Parallel scoring across multiple frameworks with result comparison"
    },
    {
      "key": "calibration",
      "summary": "Pairwise comparison, anchor correction, bias detection for accuracy improvement"
    }
  ],
  "collaboration": {
    "input": [
      "spark",
      "void",
      "accord",
      "sherpa",
      "helm",
      "nexus",
      "builder",
      "magi"
    ],
    "output": [
      "sherpa",
      "builder",
      "helm",
      "magi",
      "scribe"
    ]
  },
  "affinity": [
    {
      "project": "game",
      "level": "M"
    },
    {
      "project": "saas",
      "level": "M"
    },
    {
      "project": "ecommerce",
      "level": "M"
    },
    {
      "project": "dashboard",
      "level": "M"
    },
    {
      "project": "marketing",
      "level": "M"
    }
  ],
  "rank": null,
  "badges": [],
  "portrait": {
    "src": "../portraits/rank.png",
    "variant": "personality-archetype-chibi-paper-poly",
    "status": "generated"
  },
  "recipes": [
    {
      "subcommand": "ice",
      "label": "ICE Score",
      "default": true,
      "when": "ICE scoring (Impact × Confidence × Ease)"
    },
    {
      "subcommand": "rice",
      "label": "RICE Score",
      "default": false,
      "when": "RICE scoring (Reach × Impact × Confidence / Effort)"
    },
    {
      "subcommand": "wsjf",
      "label": "WSJF",
      "default": false,
      "when": "WSJF (Weighted Shortest Job First)"
    },
    {
      "subcommand": "moscow",
      "label": "MoSCoW",
      "default": false,
      "when": "MoSCoW method (Must/Should/Could/Won't)"
    },
    {
      "subcommand": "kano",
      "label": "Kano Model",
      "default": false,
      "when": "Kano model (customer satisfaction classification)"
    },
    {
      "subcommand": "cod",
      "label": "Cost of Delay (CD3)",
      "default": false,
      "when": "Deep CoD economic decomposition and CD3 sequencing (revenue/deadline-bound work)"
    },
    {
      "subcommand": "value-effort",
      "label": "Value vs Effort",
      "default": false,
      "when": "2x2 quadrant workshop (Quick Win/Major/Fill-In/Thankless) for visual consensus"
    },
    {
      "subcommand": "pokerplan",
      "label": "Priority Poker",
      "default": false,
      "when": "Anonymous Fibonacci voting (Wideband Delphi) to mitigate group bias"
    }
  ]
}
