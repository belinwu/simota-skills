{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://realm.local/schema/agent.schema.json",
  "title": "Agent",
  "description": "One agent entry in the Realm directory. References taxonomy via slug FKs.",
  "type": "object",
  "required": [
    "name",
    "class",
    "archetype",
    "category",
    "department",
    "description",
    "tagline",
    "capabilities",
    "collaboration",
    "affinity",
    "rank",
    "badges",
    "portrait",
    "recipes"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "name": {
      "type": "string",
      "description": "Lowercase agent slug. Unique across the directory.",
      "pattern": "^[a-z][a-z0-9-]{1,30}$"
    },
    "class": {
      "type": "string",
      "description": "FK -> taxonomy/classes.json id",
      "pattern": "^[a-z][a-z0-9-]{1,30}$"
    },
    "archetype": {
      "type": "string",
      "description": "Display archetype label sourced from class-system.md (e.g. 'Illusionist', 'Master crafter').",
      "minLength": 1,
      "maxLength": 40
    },
    "category": {
      "type": "string",
      "description": "FK -> taxonomy/categories.json id",
      "pattern": "^[a-z][a-z0-9-]{1,30}$"
    },
    "department": {
      "type": "string",
      "description": "Display department label (kept on the agent for SSG convenience; truth lives in classes.json).",
      "minLength": 1,
      "maxLength": 60
    },
    "description": {
      "type": "string",
      "description": "Short description excerpted from the agent SKILL.md description field.",
      "minLength": 1,
      "maxLength": 200
    },
    "tagline": {
      "type": "string",
      "description": "Class flavor or agent-specific one-liner.",
      "minLength": 1,
      "maxLength": 60
    },
    "capabilities": {
      "type": "array",
      "description": "Top capabilities surfaced from CAPABILITIES_SUMMARY (3-7 entries).",
      "minItems": 3,
      "maxItems": 7,
      "items": {
        "type": "object",
        "required": ["key", "summary"],
        "additionalProperties": false,
        "properties": {
          "key": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]{1,40}$"
          },
          "summary": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          }
        }
      }
    },
    "collaboration": {
      "type": "object",
      "required": ["input", "output"],
      "additionalProperties": false,
      "properties": {
        "input": {
          "type": "array",
          "description": "Upstream agent name slugs (BIDIRECTIONAL_PARTNERS.INPUT).",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]{1,30}$"
          },
          "uniqueItems": true
        },
        "output": {
          "type": "array",
          "description": "Downstream agent name slugs (BIDIRECTIONAL_PARTNERS.OUTPUT).",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]{1,30}$"
          },
          "uniqueItems": true
        }
      }
    },
    "affinity": {
      "type": "array",
      "description": "Project affinity entries derived from PROJECT_AFFINITY frontmatter.",
      "items": {
        "type": "object",
        "required": ["project", "level"],
        "additionalProperties": false,
        "properties": {
          "project": {
            "type": "string",
            "description": "FK -> taxonomy/affinities.json id",
            "pattern": "^[a-z][a-z0-9-]{1,30}$"
          },
          "level": {
            "type": "string",
            "enum": ["H", "M", "L"]
          }
        }
      },
      "uniqueItems": true
    },
    "rank": {
      "description": "Cold-start agents have rank: null. When present, tier is FK -> taxonomy/ranks.json id.",
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["tier", "title"],
          "additionalProperties": false,
          "properties": {
            "tier": {
              "type": "string",
              "enum": ["F", "E", "D", "C", "B", "A", "S", "SS"]
            },
            "title": {
              "type": "string",
              "minLength": 1,
              "maxLength": 40
            }
          }
        }
      ]
    },
    "badges": {
      "type": "array",
      "description": "Earned badges. Empty array under cold-start; field is always present.",
      "items": {
        "type": "object",
        "required": ["id", "rarity"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]{1,40}$"
          },
          "rarity": {
            "type": "string",
            "enum": ["common", "uncommon", "rare", "epic", "legendary"]
          }
        }
      }
    },
    "portrait": {
      "type": "object",
      "required": ["src", "variant", "status"],
      "additionalProperties": false,
      "properties": {
        "src": {
          "type": "string",
          "description": "Relative path from agents/{name}.json to the portrait image asset.",
          "pattern": "^(\\.\\./)+portraits/[a-z0-9-]+\\.(png|webp|jpg)$"
        },
        "variant": {
          "type": "string",
          "description": "Style variant key from realm portrait-prompts.md.",
          "enum": [
            "personality-archetype-chibi-paper-poly",
            "personality-archetype-chibi-flat",
            "personality-archetype-flat",
            "personality-archetype-low-poly",
            "heroic-fantasy"
          ]
        },
        "status": {
          "type": "string",
          "enum": ["generated", "pending"]
        }
      }
    },
    "recipes": {
      "type": "array",
      "description": "Recipes the agent exposes. Each entry includes the subcommand slug, human label, default flag, and the 'When to Use' description sourced from the agent's SKILL.md Recipes table.",
      "items": {
        "type": "object",
        "required": ["subcommand", "label", "default", "when"],
        "additionalProperties": false,
        "properties": {
          "subcommand": {
            "type": "string",
            "description": "Public subcommand slug invoked as '/<agent> <subcommand>'.",
            "pattern": "^[a-z0-9][a-z0-9-]{0,40}$"
          },
          "label": {
            "type": "string",
            "description": "Human-readable Recipe name from the SKILL.md table."
          },
          "default": {
            "type": "boolean",
            "description": "True when this Recipe is the default fallback for the agent."
          },
          "when": {
            "type": "string",
            "description": "Short description of when to invoke this Recipe (from SKILL.md 'When to Use' column)."
          }
        }
      },
      "uniqueItems": true
    }
  }
}
