{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://realm.local/schema/affinity.schema.json",
  "title": "AffinityRoster",
  "description": "Project affinity roster. agent.affinity[].project references id.",
  "type": "object",
  "required": ["version", "projects"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "projects": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/Project" }
    }
  },
  "$defs": {
    "Project": {
      "type": "object",
      "required": ["id", "label", "icon_symbol", "description"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]{1,30}$"
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 40
        },
        "icon_symbol": {
          "type": "string",
          "description": "Abstract icon descriptor used by portrait/affinity_icons (e.g. 'stacked cards').",
          "minLength": 1,
          "maxLength": 60
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        }
      }
    }
  }
}
