{
  "$schema": "https://design-tokens.github.io/community-group/format/tokens.schema.json",
  "$description": "Core layer — primitive tokens (raw scales). Theme-independent. Realm and Directory layers reference these via {core.*}; never re-define.",
  "core": {
    "color": {
      "$description": "Primitive color ramps in sRGB hex. Wide-gamut OKLCH variants documented in $extensions for progressive enhancement.",
      "lilac": {
        "100": { "$value": "#F5EFFB", "$type": "color", "$description": "Lilac 100 — softest tint, surface highlight." },
        "200": { "$value": "#E6D8F4", "$type": "color", "$description": "Lilac 200 — chip background, hover wash." },
        "300": { "$value": "#CFB6EA", "$type": "color", "$description": "Lilac 300 — decorative fill, illustration mid." },
        "400": { "$value": "#B594DD", "$type": "color", "$description": "Lilac 400 — accent, secondary interactive." },
        "500": { "$value": "#8E6BCB", "$type": "color", "$description": "Lilac 500 — primary brand accent (text on white = 4.7:1)." },
        "600": { "$value": "#6F4DB0", "$type": "color", "$description": "Lilac 600 — primary on light, text-safe (8.0:1 on white)." }
      },
      "rose": {
        "100": { "$value": "#FCEEF2", "$type": "color", "$description": "Rose 100 — softest blush tint." },
        "200": { "$value": "#F8D6DF", "$type": "color", "$description": "Rose 200 — chip wash, hover blush." },
        "300": { "$value": "#F2B3C4", "$type": "color", "$description": "Rose 300 — decorative fill, illustration mid." },
        "400": { "$value": "#E88AA3", "$type": "color", "$description": "Rose 400 — secondary accent." },
        "500": { "$value": "#D45F80", "$type": "color", "$description": "Rose 500 — secondary brand (UI 3:1+ on white)." },
        "600": { "$value": "#B0405F", "$type": "color", "$description": "Rose 600 — text-safe on white (5.6:1)." }
      },
      "ink": {
        "950": { "$value": "#0E0B17", "$type": "color", "$description": "Deepest ink — dark-mode background base." },
        "900": { "$value": "#16121F", "$type": "color", "$description": "Dark surface base." },
        "800": { "$value": "#1F1A2E", "$type": "color", "$description": "Dark surface card / light-mode strong text (15.4:1 on white)." },
        "700": { "$value": "#3A334E", "$type": "color", "$description": "Mid ink — heavy borders, dark mode card border." },
        "500": { "$value": "#5B5470", "$type": "color", "$description": "Soft ink — body secondary text light mode (6.65:1 on white)." },
        "300": { "$value": "#B8AECC", "$type": "color", "$description": "Pale ink — dark-mode body secondary (7.4:1 on ink-800)." },
        "200": { "$value": "#D8D0E5", "$type": "color", "$description": "Pale ink — decorative divider on white (1.5:1, decorative only). Use ink-400 for stateful borders." },
        "150": { "$value": "#9C8BBE", "$type": "color", "$description": "Mid-pale ink — stateful UI border on white (3.07:1 — UI 3:1 gate)." },
        "100": { "$value": "#EDE7F3", "$type": "color", "$description": "Whisper ink — hairline divider on white." },
        "50":  { "$value": "#F4EFF7", "$type": "color", "$description": "Near-white — dark-mode strong text (13.7:1 on ink-800)." }
      },
      "neutral": {
        "white":    { "$value": "#FFFFFF", "$type": "color", "$description": "Pure white — light-mode card surface." },
        "off-white":{ "$value": "#FDFAFE", "$type": "color", "$description": "Lilac-tinted near-white — light-mode page background." },
        "black":    { "$value": "#000000", "$type": "color", "$description": "Reserved; never use as dark-mode background (prefer ink-900)." }
      },
      "rank": {
        "$description": "Rank badge primitives — hue families synced 1:1 with realm/references/rank-xp-system.md Badge Color column. Values calibrated for >= 4.5:1 with paired on-ink (light or dark) per WCAG 2.2 AA.",
        "recruit-gray":     { "$value": "#4B5563", "$type": "color", "$description": "Rank F · Recruit · Gray (slate, AA with ink-50: 6.67:1)." },
        "novice-white":     { "$value": "#F3F4F6", "$type": "color", "$description": "Rank E · Novice · White (off-white; uses ink-800: 15.3:1)." },
        "apprentice-green": { "$value": "#1F6B3F", "$type": "color", "$description": "Rank D · Apprentice · Green (forest, AA with ink-50: 5.73:1)." },
        "journeyman-blue":  { "$value": "#1D4ED8", "$type": "color", "$description": "Rank C · Journeyman · Blue (cobalt, AA with ink-50: 5.92:1)." },
        "veteran-purple":   { "$value": "#6D28D9", "$type": "color", "$description": "Rank B · Veteran · Purple (royal, AA with ink-50: 6.27:1)." },
        "elite-gold":       { "$value": "#D4A017", "$type": "color", "$description": "Rank A · Elite · Gold (uses ink-800: 7.10:1)." },
        "champion-orange":  { "$value": "#EA7317", "$type": "color", "$description": "Rank S · Champion · Orange (uses ink-800: 5.59:1)." },
        "legend-red":       { "$value": "#B91C1C", "$type": "color", "$description": "Rank SS · Legend · Red (deep crimson, AA with ink-50: 5.71:1)." }
      },
      "affinity": {
        "$description": "Affinity-icon palette — aligned with portrait-prompts.md affinity icon symbol set. Distinct hues, calibrated for >= 4.5:1 vs white surface so icons remain legible at 16px.",
        "saas":       { "$value": "#7C5CD9", "$type": "color", "$description": "SaaS — stacked-cards (lilac-leaning purple, 4.78:1 on white)." },
        "ecommerce":  { "$value": "#C8395F", "$type": "color", "$description": "E-commerce — shopping bag (rose crimson, 4.99:1 on white)." },
        "mobile":     { "$value": "#0E8262", "$type": "color", "$description": "Mobile — smartphone (deep teal, 4.79:1 on white)." },
        "dashboard":  { "$value": "#1F6FCC", "$type": "color", "$description": "Dashboard — gauge (data blue, 5.00:1 on white)." },
        "marketing":  { "$value": "#A86006", "$type": "color", "$description": "Marketing — megaphone (warm umber, 4.84:1 on white)." },
        "game":       { "$value": "#A12FA1", "$type": "color", "$description": "Game — controller (magenta, 6.11:1 on white)." }
      }
    },
    "dimension": {
      "$description": "Spacing primitives on an 8px base scale. 4px allowed only for icon-to-text tight pairings.",
      "0":  { "$value": { "value": 0,  "unit": "px" }, "$type": "dimension" },
      "4":  { "$value": { "value": 4,  "unit": "px" }, "$type": "dimension", "$description": "Tight pairing only (icon-to-text)." },
      "8":  { "$value": { "value": 8,  "unit": "px" }, "$type": "dimension" },
      "12": { "$value": { "value": 12, "unit": "px" }, "$type": "dimension" },
      "16": { "$value": { "value": 16, "unit": "px" }, "$type": "dimension" },
      "24": { "$value": { "value": 24, "unit": "px" }, "$type": "dimension" },
      "32": { "$value": { "value": 32, "unit": "px" }, "$type": "dimension" },
      "48": { "$value": { "value": 48, "unit": "px" }, "$type": "dimension" },
      "64": { "$value": { "value": 64, "unit": "px" }, "$type": "dimension" }
    },
    "radius": {
      "0":   { "$value": { "value": 0,   "unit": "px" }, "$type": "dimension" },
      "4":   { "$value": { "value": 4,   "unit": "px" }, "$type": "dimension" },
      "8":   { "$value": { "value": 8,   "unit": "px" }, "$type": "dimension" },
      "12":  { "$value": { "value": 12,  "unit": "px" }, "$type": "dimension" },
      "16":  { "$value": { "value": 16,  "unit": "px" }, "$type": "dimension" },
      "24":  { "$value": { "value": 24,  "unit": "px" }, "$type": "dimension" },
      "999": { "$value": { "value": 999, "unit": "px" }, "$type": "dimension", "$description": "Pill / fully rounded." }
    },
    "fontFamily": {
      "rounded-sans": {
        "$value": ["Nunito", "Quicksand", "Plus Jakarta Sans", "system-ui", "-apple-system", "Segoe UI", "Roboto", "sans-serif"],
        "$type": "fontFamily",
        "$description": "Friendly rounded sans for body and display. Nunito primary; system fallbacks ensure availability."
      },
      "mono": {
        "$value": ["JetBrains Mono", "Fira Code", "Menlo", "Consolas", "monospace"],
        "$type": "fontFamily",
        "$description": "Monospace stack for inline-code chips and IDs."
      }
    },
    "fontWeight": {
      "regular":  { "$value": 400, "$type": "fontWeight" },
      "medium":   { "$value": 500, "$type": "fontWeight" },
      "semibold": { "$value": 600, "$type": "fontWeight" },
      "bold":     { "$value": 700, "$type": "fontWeight" },
      "extrabold":{ "$value": 800, "$type": "fontWeight" }
    },
    "fontSize": {
      "$description": "Major-Third scale (1.25). Caption=12, Body=16, H2=20, H1=25, Display=31. Mono uses Body.",
      "12": { "$value": { "value": 0.75,  "unit": "rem" }, "$type": "dimension" },
      "14": { "$value": { "value": 0.875, "unit": "rem" }, "$type": "dimension" },
      "16": { "$value": { "value": 1,     "unit": "rem" }, "$type": "dimension" },
      "20": { "$value": { "value": 1.25,  "unit": "rem" }, "$type": "dimension" },
      "25": { "$value": { "value": 1.5625,"unit": "rem" }, "$type": "dimension" },
      "31": { "$value": { "value": 1.9375,"unit": "rem" }, "$type": "dimension" },
      "39": { "$value": { "value": 2.4375,"unit": "rem" }, "$type": "dimension" }
    },
    "lineHeight": {
      "tight":   { "$value": 1.15, "$type": "number" },
      "snug":    { "$value": 1.3,  "$type": "number" },
      "normal":  { "$value": 1.5,  "$type": "number" },
      "relaxed": { "$value": 1.7,  "$type": "number" }
    },
    "letterSpacing": {
      "tight":  { "$value": { "value": -0.01, "unit": "em" }, "$type": "dimension" },
      "normal": { "$value": { "value": 0,     "unit": "em" }, "$type": "dimension" },
      "wide":   { "$value": { "value": 0.02,  "unit": "em" }, "$type": "dimension" }
    },
    "duration": {
      "instant": { "$value": { "value": 0,   "unit": "ms" }, "$type": "duration" },
      "fast":    { "$value": { "value": 150, "unit": "ms" }, "$type": "duration" },
      "base":    { "$value": { "value": 200, "unit": "ms" }, "$type": "duration" },
      "slow":    { "$value": { "value": 300, "unit": "ms" }, "$type": "duration" }
    },
    "easing": {
      "linear":  { "$value": [0, 0, 1, 1],         "$type": "cubicBezier" },
      "ease-out":{ "$value": [0.16, 1, 0.3, 1],    "$type": "cubicBezier", "$description": "Standard exit/hover ease (calm decel)." },
      "ease-in": { "$value": [0.7, 0, 0.84, 0],    "$type": "cubicBezier" },
      "ease-in-out": { "$value": [0.65, 0, 0.35, 1], "$type": "cubicBezier" }
    },
    "zIndex": {
      "base":     { "$value": 0,    "$type": "number" },
      "raised":   { "$value": 10,   "$type": "number", "$description": "Sticky chips, hovered cards." },
      "dropdown": { "$value": 1000, "$type": "number" },
      "sticky":   { "$value": 1100, "$type": "number" },
      "overlay":  { "$value": 1200, "$type": "number" },
      "modal":    { "$value": 1300, "$type": "number" },
      "popover":  { "$value": 1400, "$type": "number" },
      "toast":    { "$value": 1500, "$type": "number" },
      "tooltip":  { "$value": 1600, "$type": "number" }
    }
  }
}
