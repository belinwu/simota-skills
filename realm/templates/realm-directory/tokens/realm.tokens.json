{
  "$schema": "https://design-tokens.github.io/community-group/format/tokens.schema.json",
  "$description": "Realm layer — brand semantics. Lilac/rose pastel + ink + rank + affinity. References core.* only; never re-defines values. Light/Dark variants emitted as paired tokens (consumed via resolver or [data-theme] selector).",
  "realm": {
    "color": {
      "brand": {
        "primary":         { "$value": "{core.color.lilac.500}", "$type": "color", "$description": "Primary brand — lilac mid. Use on solid lilac surfaces; pair with ink-50 text." },
        "primary-strong":  { "$value": "{core.color.lilac.600}", "$type": "color", "$description": "Primary text-safe (8.0:1 on white) — links, brand text." },
        "primary-soft":    { "$value": "{core.color.lilac.200}", "$type": "color", "$description": "Primary wash — chip background, hover surface." },
        "secondary":       { "$value": "{core.color.rose.500}",  "$type": "color", "$description": "Secondary brand — rose mid." },
        "secondary-strong":{ "$value": "{core.color.rose.600}",  "$type": "color", "$description": "Secondary text-safe (5.6:1 on white)." },
        "secondary-soft":  { "$value": "{core.color.rose.200}",  "$type": "color", "$description": "Secondary wash — chip background, blush hover." }
      },
      "ink": {
        "$description": "Theme-aware text ink. Light values listed; dark values resolved via [data-theme='dark'] in CSS / resolver document.",
        "strong": {
          "$value": "{core.color.ink.800}",
          "$type": "color",
          "$description": "Body strong — primary readable text. Light: ink-800 on white = 15.4:1. Dark: ink-50 on ink-800 = 13.7:1.",
          "$extensions": {
            "io.realm.theme": { "light": "{core.color.ink.800}", "dark": "{core.color.ink.50}" }
          }
        },
        "soft": {
          "$value": "{core.color.ink.500}",
          "$type": "color",
          "$description": "Body secondary text. Light: ink-500 on white = 6.65:1. Dark: ink-300 on ink-800 = 7.4:1.",
          "$extensions": {
            "io.realm.theme": { "light": "{core.color.ink.500}", "dark": "{core.color.ink.300}" }
          }
        },
        "muted": {
          "$value": "{core.color.ink.500}",
          "$type": "color",
          "$description": "Caption / disabled text. AA-borderline; use only on body-size or larger.",
          "$extensions": {
            "io.realm.theme": { "light": "{core.color.ink.500}", "dark": "{core.color.ink.300}" }
          }
        },
        "inverse": {
          "$value": "{core.color.ink.50}",
          "$type": "color",
          "$description": "Inverse text — on solid lilac/rose chips and dark filled buttons.",
          "$extensions": {
            "io.realm.theme": { "light": "{core.color.ink.50}", "dark": "{core.color.ink.800}" }
          }
        }
      },
      "surface": {
        "base": {
          "$value": "{core.color.neutral.off-white}",
          "$type": "color",
          "$description": "Page background. Light: lilac-tinted off-white. Dark: ink-900.",
          "$extensions": {
            "io.realm.theme": { "light": "{core.color.neutral.off-white}", "dark": "{core.color.ink.900}" }
          }
        },
        "card": {
          "$value": "{core.color.neutral.white}",
          "$type": "color",
          "$description": "Card / panel surface. Light: white. Dark: ink-800.",
          "$extensions": {
            "io.realm.theme": { "light": "{core.color.neutral.white}", "dark": "{core.color.ink.800}" }
          }
        },
        "raised": {
          "$value": "{core.color.lilac.100}",
          "$type": "color",
          "$description": "Hover / pressed lift over base — soft lilac wash light, ink-700 dark.",
          "$extensions": {
            "io.realm.theme": { "light": "{core.color.lilac.100}", "dark": "{core.color.ink.700}" }
          }
        },
        "subtle": {
          "$value": "{core.color.lilac.100}",
          "$type": "color",
          "$description": "Subtle band background — section delineation.",
          "$extensions": {
            "io.realm.theme": { "light": "{core.color.lilac.100}", "dark": "{core.color.ink.900}" }
          }
        }
      },
      "border": {
        "subtle": {
          "$value": "{core.color.ink.100}",
          "$type": "color",
          "$description": "Hairline divider, low-contrast.",
          "$extensions": {
            "io.realm.theme": { "light": "{core.color.ink.100}", "dark": "{core.color.ink.700}" }
          }
        },
        "default": {
          "$value": "{core.color.ink.150}",
          "$type": "color",
          "$description": "Default card / input border carrying state. UI 3:1 on surface (light: 3.07:1; dark uses ink-300 6:1).",
          "$extensions": {
            "io.realm.theme": { "light": "{core.color.ink.150}", "dark": "{core.color.ink.300}" }
          }
        },
        "strong": {
          "$value": "{core.color.ink.500}",
          "$type": "color",
          "$description": "Selected / active border, high contrast.",
          "$extensions": {
            "io.realm.theme": { "light": "{core.color.ink.500}", "dark": "{core.color.ink.300}" }
          }
        },
        "focus": {
          "$value": "{core.color.lilac.600}",
          "$type": "color",
          "$description": "Focus ring color — lilac-600 on light surfaces, lilac-300 on dark. Width >= 3px.",
          "$extensions": {
            "io.realm.theme": { "light": "{core.color.lilac.600}", "dark": "{core.color.lilac.300}" }
          }
        }
      },
      "rank": {
        "$description": "Rank palette synced with rank-xp-system.md Badge Color column. fill = badge background; on = text on fill (>= 4.5:1 verified).",
        "recruit":    { "fill": { "$value": "{core.color.rank.recruit-gray}",     "$type": "color" }, "on": { "$value": "{core.color.ink.50}",  "$type": "color", "$description": "Recruit ink — 6.67:1 on slate gray." } },
        "novice":     { "fill": { "$value": "{core.color.rank.novice-white}",     "$type": "color" }, "on": { "$value": "{core.color.ink.800}", "$type": "color", "$description": "Novice ink — 15.32:1 on off-white." } },
        "apprentice": { "fill": { "$value": "{core.color.rank.apprentice-green}", "$type": "color" }, "on": { "$value": "{core.color.ink.50}",  "$type": "color", "$description": "Apprentice ink — 5.73:1 on forest green." } },
        "journeyman": { "fill": { "$value": "{core.color.rank.journeyman-blue}",  "$type": "color" }, "on": { "$value": "{core.color.ink.50}",  "$type": "color", "$description": "Journeyman ink — 5.92:1 on cobalt." } },
        "veteran":    { "fill": { "$value": "{core.color.rank.veteran-purple}",   "$type": "color" }, "on": { "$value": "{core.color.ink.50}",  "$type": "color", "$description": "Veteran ink — 6.27:1 on royal purple." } },
        "elite":      { "fill": { "$value": "{core.color.rank.elite-gold}",       "$type": "color" }, "on": { "$value": "{core.color.ink.800}", "$type": "color", "$description": "Elite ink — 7.10:1 (gold reads dark text)." } },
        "champion":   { "fill": { "$value": "{core.color.rank.champion-orange}",  "$type": "color" }, "on": { "$value": "{core.color.ink.800}", "$type": "color", "$description": "Champion ink — 5.59:1 (orange reads dark text)." } },
        "legend":     { "fill": { "$value": "{core.color.rank.legend-red}",       "$type": "color" }, "on": { "$value": "{core.color.ink.50}",  "$type": "color", "$description": "Legend ink — 5.71:1 on deep crimson." } }
      },
      "affinity": {
        "$description": "Affinity icon hues — synced with portrait-prompts.md affinity icon symbol set. All values >=4.5:1 vs white surface (light) for AA-grade icon legibility.",
        "saas":      { "$value": "{core.color.affinity.saas}",      "$type": "color", "$description": "SaaS — stacked-cards (4.78:1 on white)." },
        "ecommerce": { "$value": "{core.color.affinity.ecommerce}", "$type": "color", "$description": "E-commerce — shopping bag (4.99:1 on white)." },
        "mobile":    { "$value": "{core.color.affinity.mobile}",    "$type": "color", "$description": "Mobile — smartphone (4.79:1 on white)." },
        "dashboard": { "$value": "{core.color.affinity.dashboard}", "$type": "color", "$description": "Dashboard — gauge (5.00:1 on white)." },
        "marketing": { "$value": "{core.color.affinity.marketing}", "$type": "color", "$description": "Marketing — megaphone (4.84:1 on white)." },
        "game":      { "$value": "{core.color.affinity.game}",      "$type": "color", "$description": "Game — controller (6.11:1 on white)." }
      },
      "feedback": {
        "success": { "$value": "{core.color.rank.apprentice-green}", "$type": "color" },
        "info":    { "$value": "{core.color.rank.journeyman-blue}",  "$type": "color" },
        "warn":    { "$value": "{core.color.rank.champion-orange}",  "$type": "color" },
        "danger":  { "$value": "{core.color.rank.legend-red}",       "$type": "color" }
      }
    },
    "typography": {
      "display": {
        "$value": {
          "fontFamily": "{core.fontFamily.rounded-sans}",
          "fontSize":   "{core.fontSize.39}",
          "fontWeight": "{core.fontWeight.extrabold}",
          "lineHeight": "{core.lineHeight.tight}",
          "letterSpacing": "{core.letterSpacing.tight}"
        },
        "$type": "typography",
        "$description": "Display — hero headline."
      },
      "h1": {
        "$value": {
          "fontFamily": "{core.fontFamily.rounded-sans}",
          "fontSize":   "{core.fontSize.31}",
          "fontWeight": "{core.fontWeight.bold}",
          "lineHeight": "{core.lineHeight.snug}",
          "letterSpacing": "{core.letterSpacing.tight}"
        },
        "$type": "typography"
      },
      "h2": {
        "$value": {
          "fontFamily": "{core.fontFamily.rounded-sans}",
          "fontSize":   "{core.fontSize.25}",
          "fontWeight": "{core.fontWeight.semibold}",
          "lineHeight": "{core.lineHeight.snug}",
          "letterSpacing": "{core.letterSpacing.normal}"
        },
        "$type": "typography"
      },
      "body": {
        "$value": {
          "fontFamily": "{core.fontFamily.rounded-sans}",
          "fontSize":   "{core.fontSize.16}",
          "fontWeight": "{core.fontWeight.regular}",
          "lineHeight": "{core.lineHeight.normal}",
          "letterSpacing": "{core.letterSpacing.normal}"
        },
        "$type": "typography"
      },
      "caption": {
        "$value": {
          "fontFamily": "{core.fontFamily.rounded-sans}",
          "fontSize":   "{core.fontSize.12}",
          "fontWeight": "{core.fontWeight.medium}",
          "lineHeight": "{core.lineHeight.normal}",
          "letterSpacing": "{core.letterSpacing.wide}"
        },
        "$type": "typography",
        "$description": "Caption — meta labels (filter chips, affinity tags)."
      },
      "mono": {
        "$value": {
          "fontFamily": "{core.fontFamily.mono}",
          "fontSize":   "{core.fontSize.14}",
          "fontWeight": "{core.fontWeight.regular}",
          "lineHeight": "{core.lineHeight.normal}",
          "letterSpacing": "{core.letterSpacing.normal}"
        },
        "$type": "typography",
        "$description": "Mono — agent IDs, code chips."
      }
    },
    "spacing": {
      "none": { "$value": "{core.dimension.0}",  "$type": "dimension" },
      "xs":   { "$value": "{core.dimension.4}",  "$type": "dimension", "$description": "Tight pairing only (icon-to-text)." },
      "sm":   { "$value": "{core.dimension.8}",  "$type": "dimension" },
      "md":   { "$value": "{core.dimension.16}", "$type": "dimension" },
      "lg":   { "$value": "{core.dimension.24}", "$type": "dimension" },
      "xl":   { "$value": "{core.dimension.32}", "$type": "dimension" },
      "2xl":  { "$value": "{core.dimension.48}", "$type": "dimension" },
      "3xl":  { "$value": "{core.dimension.64}", "$type": "dimension" }
    },
    "radius": {
      "none": { "$value": "{core.radius.0}",   "$type": "dimension" },
      "sm":   { "$value": "{core.radius.4}",   "$type": "dimension" },
      "md":   { "$value": "{core.radius.8}",   "$type": "dimension" },
      "lg":   { "$value": "{core.radius.16}",  "$type": "dimension" },
      "xl":   { "$value": "{core.radius.24}",  "$type": "dimension" },
      "pill": { "$value": "{core.radius.999}", "$type": "dimension" }
    },
    "shadow": {
      "card-rest": {
        "$value": [
          { "color": "#1F1A2E14", "offsetX": { "value": 0, "unit": "px" }, "offsetY": { "value": 1, "unit": "px" }, "blur": { "value": 2, "unit": "px" }, "spread": { "value": 0, "unit": "px" }, "inset": false },
          { "color": "#1F1A2E0F", "offsetX": { "value": 0, "unit": "px" }, "offsetY": { "value": 4, "unit": "px" }, "blur": { "value": 8, "unit": "px" }, "spread": { "value": 0, "unit": "px" }, "inset": false }
        ],
        "$type": "shadow",
        "$description": "Resting card elevation — soft ink shadow."
      },
      "card-hover": {
        "$value": [
          { "color": "#8E6BCB33", "offsetX": { "value": 0, "unit": "px" }, "offsetY": { "value": 8, "unit": "px" }, "blur": { "value": 24, "unit": "px" }, "spread": { "value": -4, "unit": "px" }, "inset": false },
          { "color": "#1F1A2E14", "offsetX": { "value": 0, "unit": "px" }, "offsetY": { "value": 2, "unit": "px" }, "blur": { "value": 4, "unit": "px" }, "spread": { "value": 0, "unit": "px" }, "inset": false }
        ],
        "$type": "shadow",
        "$description": "Hover card — lilac glow halo (lilac-500 @ 20%) + base lift."
      },
      "focus-ring": {
        "$value": [
          { "color": "#6F4DB066", "offsetX": { "value": 0, "unit": "px" }, "offsetY": { "value": 0, "unit": "px" }, "blur": { "value": 0, "unit": "px" }, "spread": { "value": 3, "unit": "px" }, "inset": false }
        ],
        "$type": "shadow",
        "$description": "Focus outline — lilac-600 @ 40% spread 3px (>=3px width gate)."
      }
    },
    "motion": {
      "duration": {
        "page-transition": { "$value": "{core.duration.fast}", "$type": "duration", "$description": "150ms cross-fade between routes." },
        "hover":           { "$value": "{core.duration.base}", "$type": "duration", "$description": "200ms hover ease-out." },
        "exit":            { "$value": "{core.duration.fast}", "$type": "duration" }
      },
      "easing": {
        "default":  { "$value": "{core.easing.ease-out}",    "$type": "cubicBezier" },
        "emphasis": { "$value": "{core.easing.ease-in-out}", "$type": "cubicBezier" }
      },
      "reduce": {
        "$description": "When prefers-reduced-motion: reduce, all motion durations collapse to 0ms (instant). Consumers should branch on the media query.",
        "duration":      { "$value": "{core.duration.instant}", "$type": "duration" },
        "page-transition":{ "$value": "{core.duration.instant}", "$type": "duration" },
        "hover":         { "$value": "{core.duration.instant}", "$type": "duration" }
      }
    }
  }
}
