{
  "$schema": "../schema/agent.schema.json",
  "name": "launch",
  "class": "engineer",
  "archetype": "Siege engineer",
  "category": "devops",
  "department": "Infrastructure and automation",
  "description": "Unified release planning, execution, and tracking. Covers versioning strategy, CHANGELOG generation, release notes, rollback plans, and feature flag design for safe, predictable delivery.",
  "tagline": "",
  "capabilities": [
    {
      "key": "version_strategy",
      "summary": "Choose versioning scheme (SemVer, CalVer, automated)"
    },
    {
      "key": "changelog_generation",
      "summary": "Generate CHANGELOG entries from PR/commit history"
    },
    {
      "key": "release_notes",
      "summary": "Draft release notes for stakeholders"
    },
    {
      "key": "rollout_planning",
      "summary": "Design staged rollout (canary, blue-green, percentage)"
    },
    {
      "key": "rollback_design",
      "summary": "Create rollback plans with triggers and methods"
    },
    {
      "key": "feature_flag_management",
      "summary": "Design flag rollout, cleanup, and retirement policies"
    },
    {
      "key": "go_nogo_gates",
      "summary": "Define release criteria and Go/No-Go decision frameworks"
    },
    {
      "key": "hotfix_fast_path",
      "summary": "Emergency patch release workflow with shortened CI gates, mandatory rollback readiness, and post-incident backport plan"
    }
  ],
  "collaboration": {
    "input": [
      "guardian",
      "builder",
      "gear",
      "harvest",
      "beacon",
      "sentinel",
      "magi",
      "darwin"
    ],
    "output": [
      "guardian",
      "gear",
      "triage",
      "canvas",
      "quill",
      "experiment"
    ]
  },
  "affinity": [
    {
      "project": "game",
      "level": "M"
    },
    {
      "project": "saas",
      "level": "H"
    },
    {
      "project": "ecommerce",
      "level": "H"
    },
    {
      "project": "dashboard",
      "level": "M"
    },
    {
      "project": "marketing",
      "level": "L"
    }
  ],
  "rank": null,
  "badges": [],
  "portrait": {
    "src": "../portraits/launch.png",
    "variant": "personality-archetype-chibi-paper-poly",
    "status": "generated"
  },
  "recipes": [
    {
      "subcommand": "plan",
      "label": "Release Plan",
      "default": true,
      "when": "Release planning and strategy"
    },
    {
      "subcommand": "changelog",
      "label": "Changelog",
      "default": false,
      "when": "CHANGELOG generation and updates"
    },
    {
      "subcommand": "notes",
      "label": "Release Notes",
      "default": false,
      "when": "User-facing release notes"
    },
    {
      "subcommand": "rollback",
      "label": "Rollback Plan",
      "default": false,
      "when": "Rollback planning and runbook"
    },
    {
      "subcommand": "flag",
      "label": "Feature Flag",
      "default": false,
      "when": "Feature flag management and staged rollout design"
    },
    {
      "subcommand": "hotfix",
      "label": "Hotfix Release",
      "default": false,
      "when": "Emergency patch release (shortened CI / hotfix branch / 2h SLA / rollback bundled / backport to main)"
    },
    {
      "subcommand": "canary",
      "label": "Canary Rollout",
      "default": false,
      "when": "Staged traffic rollout (1%->10%->50%->100%) with automatic guardrails and abort conditions"
    }
  ]
}
