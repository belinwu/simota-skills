{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://realm.local/schema/category.schema.json",
  "title": "CategoryRoster",
  "description": "Roster of ecosystem categories. Bidirectional with class roster via classes[].",
  "type": "object",
  "required": ["version", "categories"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "categories": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/Category" }
    }
  },
  "$defs": {
    "Category": {
      "type": "object",
      "required": ["id", "label", "order", "signature_trait", "classes"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]{1,30}$"
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 40
        },
        "order": {
          "type": "integer",
          "minimum": 1,
          "maximum": 99
        },
        "signature_trait": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "classes": {
          "type": "array",
          "description": "Class id(s) mapped from this category. Mirrors class.category.",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]{1,30}$"
          },
          "uniqueItems": true
        }
      }
    }
  }
}
