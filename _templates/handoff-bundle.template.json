{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Handoff Bundle Template",
  "description": "Structured payload for design → code handoff. Inspired by Claude Design's handoff bundle (2026-04-17). Usage: Atelier/Vision/Forge produces this; Artisan/Builder/Claude Code consumes. Agent names are Capitalized throughout.",
  "version": "1.0.0",
  "$template_example": {
    "schema_version": "1.0.0",
    "bundle_id": "bundle-dashboard-2026-04-18-a1b2c3",
    "created_by": "atelier",
    "created_at": "2026-04-18T14:30:00Z",
    "target": {
      "agent": "Artisan",
      "framework": "Next.js 15 (App Router)",
      "language": "TypeScript",
      "platform": ["web"]
    },
    "intent": {
      "summary": "Ship-ready dashboard for on-call engineers; calm under pressure, dense but scannable.",
      "tone": ["calm", "technical", "no marketing gloss"],
      "audience": "SRE / on-call engineers",
      "dark_mode_first": true
    },
    "design_system": {
      "Registry_Ref": ".agents/design-system/observability-2026.json",
      "version": "1.3.0",
      "inline_tokens": null,
      "overrides": {
        "color.semantic.danger": "#dc2626"
      }
    },
    "assets": {
      "icons": ["assets/icons/severity-info.svg", "assets/icons/severity-critical.svg"],
      "fonts": ["fonts/Inter-Variable.woff2", "fonts/JetBrainsMono-Variable.woff2"],
      "images": [],
      "figma_refs": ["figma://file/abc123/incident-dashboard"]
    },
    "references": {
      "inspiration": [
        { "type": "url", "value": "https://linear.app/inbox", "note": "dense list + drill-down" }
      ],
      "web_captures": [
        { "path": ".agents/web-capture/datadog-dashboard-2026-04.png", "note": "metric card density" }
      ],
      "competitor_analysis": null
    },
    "variants": {
      "density": [
        { "label": "compact", "value": "3" },
        { "label": "base", "value": "4", "default": true },
        { "label": "relaxed", "value": "6" }
      ],
      "accent": [
        { "label": "cyan", "value": "#06b6d4", "default": true },
        { "label": "amber", "value": "#f59e0b" }
      ]
    },
    "components_required": [
      { "name": "IncidentList", "role": "primary-surface", "source_ref": null },
      { "name": "IncidentTimeline", "role": "drill-down", "source_ref": null },
      { "name": "SeverityBadge", "role": "atom", "source_ref": "components/ui/badge.tsx" }
    ],
    "acceptance_criteria": [
      "Incident list renders with virtualization beyond 200 rows",
      "Timeline drill-down opens in < 100ms after click",
      "Contrast ratio ≥ 7:1 for critical-severity indicators (WCAG AAA)",
      "Keyboard shortcut overlay triggered by '?' key",
      "LCP < 2.5s on mid-range laptop, TTI < 1.5s"
    ],
    "constraints": {
      "platform": ["web", "electron-shell"],
      "browsers": ["chrome-latest", "firefox-latest", "safari-latest"],
      "a11y": {
        "wcag_level": "AA",
        "keyboard_first": true,
        "screen_reader_regions": ["alert-status", "incident-severity"],
        "reduced_motion_respected": true
      },
      "performance_budget": {
        "lcp_ms": 2500,
        "tti_ms": 1500,
        "bundle_kb_initial": 200
      },
      "brand_rules": {
        "no_emojis_in_ui": true,
        "no_gradients": true,
        "logo_treatment": "monochrome-only"
      }
    },
    "code_instructions": {
      "files_to_create": [
        "app/dashboard/page.tsx",
        "components/incident/incident-list.tsx",
        "components/incident/incident-timeline.tsx",
        "components/incident/severity-badge.tsx"
      ],
      "files_to_modify": [
        "app/layout.tsx"
      ],
      "test_framework": "Playwright",
      "test_requirements": [
        "a11y snapshot via axe-playwright",
        "visual regression for 3 severity states",
        "keyboard-only flow for incident drill-down"
      ],
      "style_approach": "Tailwind + CSS variables from registry",
      "state_management": "Server Components + Server Actions; no client state library"
    },
    "do_not": {
      "colors": ["pastel", "gradient"],
      "copy_words": ["delightful", "magical", "powerful", "amazing"],
      "patterns": ["hero illustrations", "testimonial carousels", "animated splash"]
    },
    "handoff_notes": "Artisan: prioritize a11y tests before visual polish. If Timeline performance degrades past 500 events, escalate to atelier for re-scoping.",
    "traceability": {
      "Vision_Ref": ".agents/vision/direction-2026-04.md",
      "upstream_chain": ["Vision", "Atelier", "Muse", "Frame", "Forge"],
      "prd_ref": null,
      "design_ticket": null
    }
  },
  "$fields": {
    "required": [
      "schema_version",
      "bundle_id",
      "created_by",
      "created_at",
      "target",
      "intent",
      "design_system",
      "acceptance_criteria",
      "constraints",
      "code_instructions"
    ],
    "recommended": [
      "assets",
      "references",
      "variants",
      "components_required",
      "do_not",
      "traceability"
    ]
  },
  "$usage": {
    "producers": ["Atelier", "Vision (via Atelier)", "Forge", "Frame"],
    "consumers": ["Artisan", "Builder", "Pixel", "Showcase", "Claude Code"],
    "storage": ".agents/atelier/bundle-{slug}-{date}.json",
    "indexing": "Append entry to .agents/atelier/INDEX.md when bundle is created"
  },
  "$rules": [
    "bundle_id MUST be unique within a project; format: bundle-{slug}-{YYYY-MM-DD}-{6char-hash}",
    "design_system.Registry_Ref MUST point to an existing file or be null (inline tokens only)",
    "design_system.Registry_Ref and design_system.inline_tokens are mutually exclusive: if Registry_Ref is non-null, inline_tokens MUST be null; if Registry_Ref is null, inline_tokens MUST be non-null. Both non-null is a schema error; when in doubt, Registry_Ref wins",
    "acceptance_criteria MUST be measurable (numbers, ratios, paths); avoid subjective phrases",
    "constraints.a11y.wcag_level MUST be declared; default to AA if uncertain",
    "do_not is not optional for brand-sensitive work; empty object is a conscious choice",
    "Bundles are append-only once handed off; create a new bundle for revisions (do not mutate)",
    "Never embed secrets (API keys, Figma access tokens, PII) into any field. Use references to existing project config or environment variables"
  ]
}
